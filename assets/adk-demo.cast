[13.671646, "o", "\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[G\u001b[38;2;45;65;77m\u256d\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256e\u001b[39m\r\n\u001b[38;2;45;65;77m\u2502\u001b[39m                                                                                   \u001b[38;2;45;65;77m\u2502\u001b[39m\r\n\u001b[38;2;45;65;77m\u2502\u001b[39m \u001b[1mSelect Model\u001b[22m                                                                      \u001b[38;2;45;65;77m\u2502\u001b[39m\r\n\u001b[38;2;45;65;77m\u2502\u001b[39m                                                                                   \u001b[38;2;45;65;77m\u2502\u001b[39m\r\n\u001b[38;2;45;65;77m\u2502\u001b[39m \u001b[38;2;171;178;191m \u001b[39m \u001b[38;2;171;178;191m1.\u001b[39m \u001b[38;2;171;178;191mAuto (Gemini 3)\u001b[39m                                                              \u001b[38;2;45;65;77m\u2502\u001b[39m\r\n\u001b[38;2;45;65;77m\u2502\u001b[39m      \u001b[38;2;92;99;112mLet Gemini CLI decide the best model for the task: gemini-3.1-pro,\u001b[39m           \u001b[38;2;45;65;77m\u2502\u001b[39m\r\n\u001b[38;2;45;65;77m\u2502\u001b[39m      \u001b[38;2;92;99;112mgemini-3-flash\u001b[39m                                                               \u001b[38;2;45;65;77m\u2502\u001b[39m\r\n\u001b[38;2;45;65;77m\u2502\u001b[39m \u001b[38;2;152;195;121m\u25cf\u001b[39m \u001b[38;2;152;195;121m2.\u001b[39m \u001b[38;2;152;195;121mAuto (Gemini 2.5)\u001b[39m                                                            \u001b[38;2;45;65;77m\u2502\u001b[39m\r\n\u001b[38;2;45;65;77m\u2502\u001b[39m      \u001b[38;2;92;99;112mLet Gemini CLI decide the best model for the task: gemini-2.5-pro,\u001b[39m           \u001b[38;2;45;65;77m\u2502\u001b[39m\r\n\u001b[38;2;45;65;77m\u2502\u001b[39m      \u001b[38;2;92;99;112mgemini-2.5-flash\u001b[39m                                                             \u001b[38;2;45;65;77m\u2502\u001b[39m\r\n\u001b[38;2;45;65;77m\u2502\u001b[39m \u001b[38;2;171;178;191m \u001b[39m \u001b[38;2;171;178;191m3.\u001b[39m \u001b[38;2;171;178;191mManual (gemini-2.5-pro)\u001b[39m                                                      \u001b[38;2;45;65;77m\u2502\u001b[39m\r\n\u001b[38;2;45;65;77m\u2502\u001b[39m      \u001b[38;2;92;99;112mManually select a model\u001b[39m                                                      \u001b[38;2;45;65;77m\u2502\u001b[39m\r\n\u001b[38;2;45;65;77m\u2502\u001b[39m                                                                                   \u001b[38;2;45;65;77m\u2502\u001b[39m\r\n\u001b[38;2;45;65;77m\u2502\u001b[39m \u001b[38;2;171;178;191mRemember model for future sessions: \u001b[38;2;152;195;121mfalse\u001b[39m                                         \u001b[38;2;45;65;77m\u2502\u001b[39m\r\n\u001b[38;2;45;65;77m\u2502\u001b[39m \u001b[38;2;92;99;112m(Press Tab to toggle)\u001b[39m                                                             \u001b[38;2;45;65;77m\u2502\u001b[39m\r\n\u001b[38;2;45;65;77m\u2502\u001b[39m                                                                                   \u001b[38;2;45;65;77m\u2502\u001b[39m\r\n\u001b[38;2;45;65;77m\u2502\u001b[39m \u001b[38