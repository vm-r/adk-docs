[0.304791, "o", "\u001b[?1l\u001b>\u001b[?2004l\r\r\n\u001b]2;uvx agent-starter-pack create --adk my-agent\u0007\u001b]1;uvx\u0007\u001b[37m\u280b\u001b[0m \u001b[2mResolving dependencies...                                                          \u001b[0m\r\u001b[2K\u001b[37m\u2819\u001b[0m \u001b[2mResolving dependencies...                                                          \u001b[0m\r\u001b[2K\u001b[37m\u280b\u001b[0m \u001b[2mResolving dependencies...                                                          \u001b[0m\r\u001b[2K\u001b[37m\u2819\u001b[0m \u001b[2mResolving dependencies...                                                          \u001b[0m\r\u001b[2K\u001b[37m\u2819\u001b[0m \u001b[2magent-starter-pack==0.38.0                                                         \u001b[0m\r\u001b[2K\u001b[37m\u2819\u001b[0m \u001b[2mbackoff==2.2.1                                                                     \u001b[0m\r\u001b[2K\u001b[37m\u2819\u001b[0m \u001b[2mclick==8.3.1                                                                       \u001b[0m\r\u001b[2K\u001b[37m\u2819\u001b[0m \u001b[2mcookiecutter==2.7.1                                                                \u001b[0m\r\u001b[2K\u001b[37m\u2819\u001b[0m \u001b[2mgoogle-cloud-aiplatform==1.140.0                                                   \u001b[0m"]
[0.804791, "o", "\r\n\u001b[1;34m=== Google Cloud Agent Starter Pack \ud83d\ude80===\u001b[0m\r\nWelcome to the Agent Starter Pack!\r\nThis tool will help you create an end-to-end production-ready AI agent in Google \r\nCloud!\r\n\r\n\u001b[36m\u26a1 ADK quickstart: adk + Agent Engine + prototype mode\u001b[0m\r\n\r\n> Verifying GCP credentials\u001b[33m...\u001b[0m\r\n"]
[1.304791, "o", "> \u2713 Connected to project: developer-sandbox\r\n"]
[1.804791, "o", "\r\n\u001b[1;32m\u2705 Success!\u001b[0m Your agent project is ready.\r\n\r\n\u001b[1;36m\ud83d\udcd6 Documentation\u001b[0m\r\n   README:    \u001b[36mcat my-agent/README.md\u001b[0m\r\n   Dev Guide: \u001b]8;id=213769;https://goo.gle/asp-dev\u001b\\\u001b[4;36mhttps://goo.gle/asp-dev\u001b[0m\u001b]8;;\u001b\\\r\n\r\n\u001b[1;36m\ud83d\udca1 Tip\u001b[0m\r\n   Once ready for production, run: \u001b[36muvx agent-starter-pack enhance\u001b[0m\r\n\r\n\u001b[1;36m\ud83d\ude80 Get Started\u001b[0m\r\n   \u001b[1;92mcd my-agent && make install && make playground\u001b[0m\r\n"]
[2.06062, "o", "\u001b[1m\u001b[7m%\u001b[27m\u001b[1m\u001b[0m                                                                                    \r \r\u001b]2;developer@developer-mac:/tmp\u0007\u001b]1;/tmp\u0007\u001b]7;file://developer-mac.local/tmp\u001b\\\r\u001b[0m\u001b[27m\u001b[24m\u001b[J\u001b[01;32m\u279c  \u001b[36m/tmp\u001b[00m \u001b[K\u001b[?1h\u001b=\u001b[?2004h"]
[2.56062, "o", "\u001b[7muvx --extra-index-url https://us-central1-python.pkg.dev/asp-test-dev/adk-pac\u001b[7mk\u001b[7mages/simple/ --index-strategy unsafe-best-match --from \"google-adk[mcp-server]>=1.24\u001b[7m,\u001b[7m<1.25\" adk mcp setup\u001b[27m\u001b[K"]
[3.06062, "o", "\u001b[A\u001b[A\u001b[13D\u001b[27mu\u001b[27mv\u001b[27mx\u001b[27m \u001b[27m-\u001b[27m-\u001b[27me\u001b[27mx\u001b[27mt\u001b[27mr\u001b[27ma\u001b[27m-\u001b[27mi\u001b[27mn\u001b[27md\u001b[27me\u001b[27mx\u001b[27m-\u001b[27mu\u001b[27mr\u001b[27ml\u001b[27m \u001b[27mh\u001b[27mt\u001b[27mt\u001b[27mp\u001b[27ms\u001b[27m:\u001b[27m/\u001b[27m/\u001b[27mu\u001b[27ms\u001b[27m-\u001b[27mc\u001b[27me\u001b[27mn\u001b[27mt\u001b[27mr\u001b[27ma\u001b[27ml\u001b[27m1\u001b[27m-\u001b[27mp\u001b[27my\u001b[27mt\u001b[27mh\u001b[27mo\u001b[27mn\u001b[27m.\u001b[27mp\u001b[27mk\u001b[27mg\u001b[27m.\u001b[27md\u001b[27me\u001b[27mv\u001b[27m/\u001b[27ma\u001b[27ms\u001b[27mp\u001b[27m-\u001b[27mt\u001b[27me\u001b[27ms\u001b[27mt\u001b[27m-\u001b[27md\u001b[27me\u001b[27mv\u001b[27m/\u001b[27ma\u001b[27md\u001b[27mk\u001b[27m-\u001b[27mp\u001b[27ma\u001b[27mck\u001b[27ma\u001b[27mg\u001b[27me\u001b[27ms\u001b[27m/\u001b[27ms\u001b[27mi\u001b[27mm\u001b[27mp\u001b[27ml\u001b[27me\u001b[27m/\u001b[27m \u001b[27m-\u001b[27m-\u001b[27mi\u001b[27mn\u001b[27md\u001b[27me\u001b[27mx\u001b[27m-\u001b[27ms\u001b[27mt\u001b[27mr\u001b[27ma\u001b[27mt\u001b[27me\u001b[27mg\u001b[27my\u001b[27m \u001b[27mu\u001b[27mn\u001b[27ms\u001b[27ma\u001b[27mf\u001b[27me\u001b[27m-\u001b[27mb\u001b[27me\u001b[27ms\u001b[27mt\u001b[27m-\u001b[27mm\u001b[27ma\u001b[27mt\u001b[27mc\u001b[27mh\u001b[27m \u001b[27m-\u001b[27m-\u001b[27mf\u001b[27mr\u001b[27mo\u001b[27mm\u001b[27m \u001b[27m\"\u001b[27mg\u001b[27mo\u001b[27mo\u001b[27mg\u001b[27ml\u001b[27me\u001b[27m-\u001b[27ma\u001b[27md\u001b[27mk\u001b[27m[\u001b[27mm\u001b[27mc\u001b[27mp\u001b[27m-\u001b[27ms\u001b[27me\u001b[27mr\u001b[27mv\u001b[27me\u001b[27mr\u001b[27m]\u001b[27m>\u001b[27m=\u001b[27m1\u001b[27m.\u001b[27m2\u001b[27m4,\u001b[27m<\u001b[27m1\u001b[27m.\u001b[27m2\u001b[27m5\u001b[27m\"\u001b[27m \u001b[27ma\u001b[27md\u001b[27mk\u001b[27m \u001b[27mm\u001b[27mc\u001b[27mp\u001b[27m \u001b[27ms\u001b[27me\u001b[27mt\u001b[27mu\u001b[27mp\u001b[?1l\u001b>\u001b[?2004l\r\r\n\u001b]2;uvx --extra-index-url  --index-strategy unsafe-best-match --from  adk mcp \u0007\u001b]1;uvx\u0007\u001b[37m\u280b\u001b[0m \u001b[2mResolving dependencies...                                                          \u001b[0m\r\u001b[2K\u001b[37m\u2819\u001b[0m \u001b[2mResolving dependencies...                                                          \u001b[0m\r\u001b[2K\u001b[37m\u280b\u001b[0m \u001b[2mResolving dependencies...                                                          \u001b[0m\r\u001b[2K\u001b[37m\u2819\u001b[0m \u001b[2mResolving dependencies...                                                          \u001b[0m"]
