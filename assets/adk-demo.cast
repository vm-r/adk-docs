e-cloud-bigtable==2.35.0                                                      \u001b[0m\r\u001b[2K\u001b[37m\u2819\u001b[0m \u001b[2mgoogle-cloud-discoveryengine==0.13.12                                              \u001b[0m\r\u001b[2K\u001b[37m\u2819\u001b[0m \u001b[2mgoogle-cloud-pubsub==2.35.0                                                        \u001b[0m\r\u001b[2K\u001b[37m\u2819\u001b[0m \u001b[2mgoogle-cloud-secret-manager==2.26.0                                                \u001b[0m\r\u001b[2K\u001b[37m\u2819\u001b[0m \u001b[2mgoogle-cloud-spanner==3.63.0                                                       \u001b[0m\r\u001b[2K\u001b[37m\u2819\u001b[0m \u001b[2mgoogle-cloud-speech==2.37.0                                                        \u001b[0m\r\u001b[2K\u001b[37m\u2819\u001b[0m \u001b[2mgoogle-cloud-storage==3.9.0                                                        \u001b[0m\r\u001b[2K\u001b[37m\u2819\u001b[0m \u001b[2mgoogle-cloud-storage==3.9.0                                                        \u001b[0m\r\u001b[2K\u001b[37m\u2819\u001b[0m \u001b[2mgoogle-genai==1.66.0                                                               \u001b[0m"]
