;192;123m\u2502\u001b[39m \u001b[38;2;97;174;238m\u2514\u2500\u2500\u2500SKILL.md\u001b[39m                                                                      \u001b[38;2;230;192;123m\u2502\u001b[39m\r\n\u001b[38;2;230;192;123m\u2502\u001b[39m \u001b[38;2;171;178;191mDo you want to proceed?\u001b[39m                                                           \u001b[38;2;230;192;123m\u2502\u001b[39m\r\n\u001b[38;2;230;192;123m\u2502\u001b[39m                                                                                   \u001b[38;2;230;192;123m\u2502\u001b[39m\r\n\u001b[38;2;230;192;123m\u2502\u001b[39m \u001b[38;2;152;195;121m\u25cf\u001b[39m \u001b[38;2;152;195;121m1.\u001b[39m \u001b[38;2;152;195;121mAllow once\u001b[39m                                                                   \u001b[38;2;230;192;123m\u2502\u001b[39m\r\n\u001b[38;2;230;192;123m\u2502\u001b[39m \u001b[38;2;171;178;191m \u001b[39m \u001b[38;2;171;178;191m2.\u001b[39m \u001b[38;2;171;178;191mAllow for this session\u001b[39m                                                       \u001b[38;2;230;192;123m\u2502\u001b[39m\r\n\u001b[38;2;230;192;123m\u2502\u001b[39m \u001b[38;2;171;178;191m \u001b[39m \u001b[38;2;171;178;191m3.\u001b[39m \u001b[38;2;171;178;191mNo, suggest changes (esc)\u001b[39m                                                    \u001b[38;2;230;192;123m\u2502\u001b[39m\r\n\u001b[38;2;230;192;123m\u2502\u001b[39m                                                                                   \u001b[38;2;230;192;123m\u2502\u001b[39m\r\n\u001b[38;2;230;192;123m\u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u25